import subprocess 
import os 
import time 
import re 

def run_command(command): 
    try: 
        result = subprocess.run(command, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True) 
        return result.stdout.splitlines() 
    except Exception as e: 
        print(f"Error al ejecutar {command}: {str(e)}") 
        return [] 
    
def sublist3r_search(domain): 
    command = ["python3", "/home/fernandoapaza/subdomain_finder/Sublist3r/sublist3r.py", "-d", domain] 
    return run_command(command) 

def theharvester_search(domain): 
    command = ["python3", "/home/fernandoapaza/subdomain_finder/theHarvester/theHarvester.py", "-d", domain, "-b", "yahoo"] 
    return run_command(command) 
 
def knockpy_search(domain): 
    command = ["python3", "knockpy.py", domain] 
    return run_command(command)  
def findomain_search(domain): 
    command = ["./findomain", "-t", domain] 
    return run_command(command) 
def get_subdomains(domain): 
    subdomains = set()  
    subdomains.update(limpiar_subdominios(sublist3r_search(domain), domain)) 
    subdomains.update(limpiar_subdominios(theharvester_search(domain), domain)) 
    subdomains.update(limpiar_subdominios(knockpy_search(domain), domain)) 
    subdomains.update(limpiar_subdominios(findomain_search(domain), domain)) 
    
    sorted_subdomains = sorted(subdomains) 
    # Guardar en un archivo 
    with open(f"{domain}_subdomains.txt", "w") as file: 
        for sub in sorted_subdomains: 
            file.write(sub + "\n") 
    print(f"Subdominios guardados en {domain}_subdomains.txt") 

def limpiar_subdominios(lineas, dominio): 
    subdominios = set() 
    patron = re.compile(rf"([a-zA-Z0-9_-]+\.)+{re.escape(dominio)}")
    
    for linea in lineas:
        encontrados = patron.findall(linea) 
        for _ in encontrados: 
            match = patron.search(linea) 
            if match: 
                subdominios.add(match.group()) 
    return subdominios 
    
